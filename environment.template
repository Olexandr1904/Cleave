# Sickle — Required Environment Variables
# Copy this file to .env and fill in the values.

# Claude API key — leave empty to use the Claude Code CLI adapter
# (browser-authenticated Max/Pro subscription). Set this only if you want
# to bill the Anthropic API directly. Auto-detected at startup.
CLAUDE_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=-100...

# Jira Cloud
JIRA_URL=https://your-org.atlassian.net
JIRA_TOKEN=...
JIRA_EMAIL=you@your-org.com

# GitHub (Personal Access Token with repo scope)
GITHUB_TOKEN=ghp_...
